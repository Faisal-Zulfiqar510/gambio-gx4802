# Apache 2.2
<IfModule !mod_authz_core.c>
    <Files *.html>
		Order deny,allow
		Deny from all
    </Files>
    <Files *.scss>
		Order deny,allow
		Deny from all
    </Files>
    <Files *.php>
		Order deny,allow
		Deny from all
    </Files>
    <Files *.js>
		Order deny,allow
		Deny from all
    </Files>
    <Files *.css>
		Order deny,allow
		Deny from all
    </Files>
</IfModule>

# Apache 2.4
<IfModule mod_authz_core.c>
    <Files *.html>
		Require all denied
    </Files>
    <Files *.scss>
		Require all denied
    </Files>
    <Files *.php>
		Require all denied
    </Files>
    <Files *.js>
		Require all denied
    </Files>
    <Files *.css>
		Require all denied
    </Files>
</IfModule>
